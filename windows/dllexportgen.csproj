<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <StartupObject>dllexportgen.dllexportgen</StartupObject>
  </PropertyGroup>

  <Target Name="PostBuild" AfterTargets="PostBuildEvent" Condition="'$(SolutionDir)' != '' And '$(SolutionDir)' != '*Undefined*'">
    <Exec Command="&quot;$(TargetDir)$(AssemblyName).exe&quot; &quot;$(SolutionDir.TrimEnd('\\'))&quot;" />
  </Target>

</Project>
